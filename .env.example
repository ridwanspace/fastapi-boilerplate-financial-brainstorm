# ============================================================================
# Application
# ============================================================================
APP_ENV=development                         # development | staging | production
APP_NAME="FastAPI Financial"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR | CRITICAL

# ============================================================================
# API
# ============================================================================
API_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ============================================================================
# Database - PostgreSQL
# ============================================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/financial_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Test database (used in integration tests)
TEST_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/financial_test_db

# ============================================================================
# Redis
# ============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# Google Cloud Storage
# ============================================================================
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
GCS_CREDENTIALS_PATH=/path/to/service-account.json  # Optional if using ADC
# GCS_CREDENTIALS_JSON={}                            # Alternative: inline JSON string

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_DEFAULT=200/minute
RATE_LIMIT_AUTH=10/minute

# ============================================================================
# Sentry (optional - error tracking)
# ============================================================================
# SENTRY_DSN=https://...@sentry.io/...
